# Dependencies
node_modules/
package-lock.json
yarn.lock

# Build outputs
dist/
build/
*.js
*.js.map
*.d.ts
*.d.ts.map
!jest.config.js
!jest.globalSetup.js
# Operational scripts checked into source (e.g. F-9 verify-evidence.js).
# The blanket `*.js` rule above would otherwise hide these hand-written
# entry points alongside compiled TypeScript output.
!scripts/**/*.js
# k6 perf scenarios (I-22) — checked into source so ops can run them
# against deployed environments. Without this exception the blanket
# `*.js` rule above would silently drop them at commit time.
!packages/integration-tests/perf/k6/**/*.js
# AWS Lambda authorizer source (Sprint-1 multi-cloud parity for APIM
# `validate-jwt`). The blanket `*.js` rule above would otherwise hide
# this hand-written infra file alongside compiled TypeScript output.
!infra/**/*.js

# Environment variables
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/

# TypeScript incremental build artifacts
*.tsbuildinfo

# Temporary files
tmp/
temp/
*.tmp
