<!--
  Apigee X policy: validate the Euno capability JWT.

  Sprint-1 multi-cloud parity for the Azure APIM `validate-jwt` policy and
  the AWS API Gateway custom Lambda authorizer in
  ../../aws/api-gateway/lambda-authorizer.js.

  Drop this into an Apigee proxy bundle's `/policies/` directory and
  reference it from the proxy's PreFlow:

    <Step>
      <Name>VerifyCapabilityToken</Name>
    </Step>

  It performs the same edge checks as `packages/tool-gateway/src/verifier.ts`:
  signature (via JWKS), audience, issuer, expiration. Scope-based payload
  validation still happens in the in-cluster Tool Gateway pod so the policy
  lives in exactly one place.
-->
<VerifyJWT name="VerifyCapabilityToken" continueOnError="false" enabled="true">
  <DisplayName>Verify Euno capability JWT</DisplayName>
  <Algorithm>RS256</Algorithm>
  <Source>request.header.authorization.bearer</Source>
  <PublicKey>
    <!--
      JWKS endpoint of the Capability Issuer.  Apigee handles caching,
      key rotation, and kid lookup automatically.
    -->
    <JWKS uri="https://issuer.euno.example/.well-known/jwks.json"/>
  </PublicKey>
  <Issuer>https://issuer.euno.example</Issuer>
  <Audience>tool-gateway</Audience>
  <AdditionalClaims>
    <!--
      Make the parsed claims available to subsequent policies (logging,
      analytics, custom rate-limiting per `sub`, etc.) under the
      `jwt.VerifyCapabilityToken.claim.*` flow variables.
    -->
    <Claim name="sub"/>
    <Claim name="jti"/>
    <Claim name="capabilities" type="string"/>
  </AdditionalClaims>
  <!--
    By default Apigee returns 401 on failure.  Override the fault response
    to mirror the Tool Gateway's response shape.
  -->
  <IgnoreUnresolvedVariables>false</IgnoreUnresolvedVariables>
</VerifyJWT>
