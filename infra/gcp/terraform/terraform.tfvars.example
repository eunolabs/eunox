# Example tfvars for the modular GCP deployment.
# Copy to terraform.tfvars and customize before `terraform apply`.

project_id  = "my-gcp-project-id"
gcp_region  = "us-central1"
name_prefix = "euno"
environment = "prod"

# Networking — adjust to fit your existing VPC CIDR plan.
subnet_cidr   = "10.50.0.0/20"
pods_cidr     = "10.52.0.0/14"
services_cidr = "10.56.0.0/20"

# GKE — start small for pilot; autoscaler raises up to gke_node_max_count.
gke_node_machine_type = "e2-standard-4"
gke_node_count        = 1
gke_node_max_count    = 3

# Cloud SQL — use a larger tier for production workloads.
db_tier       = "db-custom-2-7680"   # 2 vCPU, 7.5 GiB RAM
db_ha_enabled = true                 # set false for staging to reduce cost

# Memorystore — STANDARD_HA for production; BASIC for staging/dev.
redis_tier           = "STANDARD_HA"
redis_memory_size_gb = 4

# Logging retention.
log_retention_days = 90

labels = {
  product   = "euno"
  component = "capability-governance"
  owner     = "platform-team"
}
