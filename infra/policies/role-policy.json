{
  "_comment": "Seed role-to-capability policy for the local stack and smoke tests. Copy this file to infra/policies/role-policy.json and mount it at /app/policies/role-policy.json inside the capability-issuer container. Set ROLE_POLICY_FILE=/app/policies/role-policy.json in the issuer environment.",
  "default": {
    "developer": [
      { "resource": "api://smoke/**", "actions": ["read", "write"] },
      { "resource": "api://tools/**", "actions": ["read", "write", "execute"] }
    ],
    "SalesManager": [
      { "resource": "api://crm/customers", "actions": ["read", "write"] },
      { "resource": "api://crm/reports", "actions": ["read"] },
      { "resource": "storage://sales-data/**", "actions": ["read", "write"] }
    ],
    "Viewer": [
      { "resource": "api://crm/customers", "actions": ["read"] },
      { "resource": "api://crm/reports", "actions": ["read"] },
      { "resource": "storage://sales-data/**", "actions": ["read"] }
    ],
    "DataScientist": [
      { "resource": "api://analytics/**", "actions": ["read", "write"] },
      { "resource": "storage://datasets/**", "actions": ["read"] },
      { "resource": "api://ml-models/**", "actions": ["read", "execute"] }
    ],
    "Administrator": [
      { "resource": "api://**", "actions": ["read", "write", "admin"] },
      { "resource": "storage://**", "actions": ["read", "write", "delete"] }
    ]
  }
}
