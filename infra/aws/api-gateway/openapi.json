{
  "openapi": "3.0.1",
  "info": {
    "title": "Eunox Tool Gateway (AWS API Gateway profile)",
    "description": "Sprint-1 multi-cloud parity for the Azure APIM `validate-jwt` policy. This OpenAPI document is consumable by `aws apigateway import-rest-api` (or via the `aws_api_gateway_rest_api` Terraform resource with `body = file(...)`). It enforces capability-token verification at the edge using a Lambda authorizer (whose source is in `lambda-authorizer.js`) before forwarding to the in-cluster Tool Gateway service.\n\nFlow:\n  client → API Gateway (custom-authorizer = `EunoxCapabilityAuthorizer`) → ALB / NLB → tool-gateway pod\n\nThe Lambda authorizer performs the same checks as `packages/tool-gateway/src/verifier.ts`: signature, audience, expiration. Scope-based payload validation still happens in the Tool Gateway pod itself (so the policy stays in one place).",
    "version": "0.1.0",
    "x-eunox-parity": "infra/bicep/main.bicep + APIM validate-jwt"
  },
  "x-amazon-apigateway-request-validators": {
    "all": {
      "validateRequestBody": true,
      "validateRequestParameters": true
    }
  },
  "x-amazon-apigateway-request-validator": "all",
  "components": {
    "securitySchemes": {
      "EunoxCapabilityAuthorizer": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header",
        "x-amazon-apigateway-authtype": "custom",
        "x-amazon-apigateway-authorizer": {
          "type": "request",
          "identitySource": "method.request.header.Authorization",
          "authorizerUri": "arn:aws:apigateway:${AWS_REGION}:lambda:path/2015-03-31/functions/${AUTHORIZER_LAMBDA_ARN}/invocations",
          "authorizerResultTtlInSeconds": 0,
          "authorizerCredentials": "${API_GATEWAY_INVOKE_ROLE_ARN}"
        }
      }
    }
  },
  "security": [{ "EunoxCapabilityAuthorizer": [] }],
  "paths": {
    "/api/v1/tools/invoke": {
      "post": {
        "summary": "Invoke a registered tool with a capability token",
        "x-amazon-apigateway-integration": {
          "type": "http_proxy",
          "httpMethod": "POST",
          "uri": "${UPSTREAM_TOOL_GATEWAY_URL}/api/v1/tools/invoke",
          "connectionType": "VPC_LINK",
          "connectionId": "${VPC_LINK_ID}",
          "passthroughBehavior": "when_no_match",
          "timeoutInMillis": 29000
        },
        "responses": {
          "200": { "description": "Tool invocation succeeded" },
          "401": { "description": "Missing/invalid/expired capability token" },
          "403": { "description": "Token valid but lacks required scope" }
        }
      }
    },
    "/proxy/{proxy+}": {
      "x-amazon-apigateway-any-method": {
        "summary": "Generic proxy for tool endpoints",
        "parameters": [
          {
            "name": "proxy",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "x-amazon-apigateway-integration": {
          "type": "http_proxy",
          "httpMethod": "ANY",
          "uri": "${UPSTREAM_TOOL_GATEWAY_URL}/proxy/{proxy}",
          "connectionType": "VPC_LINK",
          "connectionId": "${VPC_LINK_ID}",
          "passthroughBehavior": "when_no_match",
          "requestParameters": {
            "integration.request.path.proxy": "method.request.path.proxy"
          },
          "timeoutInMillis": 29000
        },
        "responses": {
          "200": { "description": "Proxied response" },
          "401": { "description": "Missing/invalid/expired capability token" },
          "403": { "description": "Token valid but lacks required scope" }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Public health check (no auth)",
        "security": [],
        "x-amazon-apigateway-integration": {
          "type": "http_proxy",
          "httpMethod": "GET",
          "uri": "${UPSTREAM_TOOL_GATEWAY_URL}/health",
          "connectionType": "VPC_LINK",
          "connectionId": "${VPC_LINK_ID}",
          "passthroughBehavior": "when_no_match",
          "timeoutInMillis": 5000
        },
        "responses": { "200": { "description": "OK" } }
      }
    }
  }
}
