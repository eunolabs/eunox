# ---------------------------------------------------------------------------
# Euno AWS Terraform — example tfvars
#
# Copy to terraform.tfvars and fill in the values specific to your deployment.
# Do NOT commit terraform.tfvars to version control (add to .gitignore).
# ---------------------------------------------------------------------------

aws_region     = "us-east-1"
aws_account_id = "123456789012"   # replace with your AWS account ID

name_prefix = "euno"
environment = "prod"             # pilot | staging | prod

# ── Networking ────────────────────────────────────────────────────────────────
vpc_cidr = "10.40.0.0/16"

# ── Compute ───────────────────────────────────────────────────────────────────
kubernetes_version = "1.30"
use_fargate        = true        # set false to use managed node groups (e.g. dev)

# ── Data stores ───────────────────────────────────────────────────────────────
db_instance_class = "db.t3.medium"    # db.m6g.large recommended for production
db_multi_az       = true
cache_node_type   = "cache.t3.medium" # cache.m6g.large recommended for production
cache_num_replicas = 1

# redis_auth_token is sensitive — supply via environment variable:
#   export TF_VAR_redis_auth_token="<your-redis-auth-token>"
# Or use a secrets manager data source:
#   redis_auth_token = data.aws_secretsmanager_secret_version.redis.secret_string

# ── Identity ──────────────────────────────────────────────────────────────────
enable_cognito        = true
cognito_domain_prefix = "euno-prod"   # must be globally unique in the AWS region

# ── Observability ─────────────────────────────────────────────────────────────
log_retention_days        = 90
alarm_notification_email  = "ops@example.com"   # leave empty to skip email subscription
enable_security_hub       = true

# ── Resource tags ─────────────────────────────────────────────────────────────
tags = {
  product     = "euno"
  component   = "capability-governance"
  environment = "prod"
  owner       = "platform-team"
}
