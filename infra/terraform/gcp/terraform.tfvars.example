# Example tfvars for the GCP deployment.
# Copy to terraform.tfvars and customize before `terraform apply`.

project_id  = "euno-pilot-123456"
gcp_region  = "us-central1"
name_prefix = "euno"
environment = "pilot"

log_retention_days = 90

# GKE sizing — keep small for the pilot, autoscaler raises up to max.
gke_node_machine_type = "e2-standard-4"
gke_node_count        = 1
gke_node_max_count    = 3

# Networking — adjust to fit your existing VPC plan.
subnet_cidr   = "10.50.0.0/20"
pods_cidr     = "10.52.0.0/14"
services_cidr = "10.56.0.0/20"

# Set both of these together if you want SCC notification config provisioned.
# Requires SCC Premium tier and Org-level admin permissions.
enable_scc_notification = false
scc_organization_id     = ""

labels = {
  product   = "euno"
  component = "capability-governance"
  owner     = "platform-team"
}
