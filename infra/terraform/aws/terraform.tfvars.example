# Example tfvars for the AWS deployment.
# Copy to terraform.tfvars and customize before `terraform apply`.

name_prefix         = "euno"
aws_region          = "us-east-1"
environment         = "pilot"
log_retention_days  = 90

# EKS sizing — start small for the pilot, scale up via desired/max in prod.
eks_kubernetes_version = "1.30"
eks_node_instance_type = "t3.large"
eks_node_desired_size  = 3
eks_node_max_size      = 9

# Networking — adjust to fit your existing VPC plan.
vpc_cidr             = "10.40.0.0/16"
public_subnet_cidrs  = ["10.40.0.0/20", "10.40.16.0/20", "10.40.32.0/20"]
private_subnet_cidrs = ["10.40.64.0/20", "10.40.80.0/20", "10.40.96.0/20"]

# Set to false if Security Hub is enabled at the AWS Organizations level
# (avoids "AccessDeniedException" or duplicate-enable errors).
enable_security_hub = true

tags = {
  product   = "euno"
  component = "capability-governance"
  owner     = "platform-team"
}
