{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build All",
      "type": "shell",
      "command": "go build ./...",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$go"]
    },
    {
      "label": "Test All",
      "type": "shell",
      "command": "go test -race -count=1 ./...",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": ["$go"]
    },
    {
      "label": "Test Package",
      "type": "shell",
      "command": "go test -race -count=1 -v ${relativeFileDirname}/...",
      "group": "test",
      "problemMatcher": ["$go"]
    },
    {
      "label": "Lint",
      "type": "shell",
      "command": "make lint",
      "group": "test",
      "problemMatcher": ["$go"]
    },
    {
      "label": "Coverage",
      "type": "shell",
      "command": "make coverage",
      "group": "test",
      "problemMatcher": ["$go"]
    },
    {
      "label": "Generate",
      "type": "shell",
      "command": "make generate",
      "group": "build",
      "problemMatcher": ["$go"]
    },
    {
      "label": "Check License Headers",
      "type": "shell",
      "command": "make check-license",
      "group": "test",
      "problemMatcher": []
    }
  ]
}
