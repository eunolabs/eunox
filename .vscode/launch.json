{
  "version": "0.2.0",
  "configurations": [
    // -------------------------------------------------------------------------
    // @euno/mcp — proxy in stdio mode (wrap a local server script)
    // -------------------------------------------------------------------------
    {
      "name": "euno-mcp: proxy (stdio)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--require", "ts-node/register"],
      "args": [
        "${workspaceFolder}/public/packages/mcp/src/cli.ts",
        "proxy",
        "--policy",
        "${input:policyFile}",
        "--",
        "node",
        "${input:upstreamScript}"
      ],
      "cwd": "${workspaceFolder}/public/packages/mcp",
      "env": {
        "TS_NODE_PROJECT": "${workspaceFolder}/public/packages/mcp/tsconfig.json"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "preLaunchTask": "build: @euno/mcp",
      "presentation": {
        "group": "mcp",
        "order": 1
      }
    },
    // -------------------------------------------------------------------------
    // @euno/mcp — proxy in HTTP mode
    // -------------------------------------------------------------------------
    {
      "name": "euno-mcp: proxy (HTTP, port 7391)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--require", "ts-node/register"],
      "args": [
        "${workspaceFolder}/public/packages/mcp/src/cli.ts",
        "proxy",
        "--transport",
        "http",
        "--port",
        "7391",
        "--policy",
        "${input:policyFile}",
        "--",
        "node",
        "${input:upstreamScript}"
      ],
      "cwd": "${workspaceFolder}/public/packages/mcp",
      "env": {
        "TS_NODE_PROJECT": "${workspaceFolder}/public/packages/mcp/tsconfig.json"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "preLaunchTask": "build: @euno/mcp",
      "presentation": {
        "group": "mcp",
        "order": 2
      }
    },
    // -------------------------------------------------------------------------
    // @euno/mcp — validate a policy file
    // -------------------------------------------------------------------------
    {
      "name": "euno-mcp: validate policy",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--require", "ts-node/register"],
      "args": [
        "${workspaceFolder}/public/packages/mcp/src/cli.ts",
        "validate",
        "${input:policyFile}"
      ],
      "cwd": "${workspaceFolder}/public/packages/mcp",
      "env": {
        "TS_NODE_PROJECT": "${workspaceFolder}/public/packages/mcp/tsconfig.json"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "preLaunchTask": "build: @euno/mcp",
      "presentation": {
        "group": "mcp",
        "order": 3
      }
    },
    // -------------------------------------------------------------------------
    // @euno/mcp — stats CLI (audit log histogram)
    // -------------------------------------------------------------------------
    {
      "name": "euno-mcp: stats",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--require", "ts-node/register"],
      "args": [
        "${workspaceFolder}/public/packages/mcp/src/cli.ts",
        "stats"
      ],
      "cwd": "${workspaceFolder}/public/packages/mcp",
      "env": {
        "TS_NODE_PROJECT": "${workspaceFolder}/public/packages/mcp/tsconfig.json"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "preLaunchTask": "build: @euno/mcp",
      "presentation": {
        "group": "mcp",
        "order": 4
      }
    },
    // -------------------------------------------------------------------------
    // @euno/mcp — validate-token CLI (audit record inspector)
    // -------------------------------------------------------------------------
    {
      "name": "euno-mcp: validate-token (--request-id)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--require", "ts-node/register"],
      "args": [
        "${workspaceFolder}/public/packages/mcp/src/cli.ts",
        "validate-token",
        "--request-id",
        "${input:requestId}"
      ],
      "cwd": "${workspaceFolder}/public/packages/mcp",
      "env": {
        "TS_NODE_PROJECT": "${workspaceFolder}/public/packages/mcp/tsconfig.json"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "preLaunchTask": "build: @euno/mcp",
      "presentation": {
        "group": "mcp",
        "order": 5
      }
    },
    // -------------------------------------------------------------------------
    // Jest tests — current open file
    // -------------------------------------------------------------------------
    {
      "name": "Jest: current test file",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/jest",
      "runtimeArgs": [
        "--testPathPattern",
        "${relativeFile}",
        "--forceExit",
        "--runInBand"
      ],
      "cwd": "${fileDirname}/../../..",
      "env": {},
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "tests",
        "order": 1
      }
    },
    // -------------------------------------------------------------------------
    // Jest tests — @euno/mcp full suite
    // -------------------------------------------------------------------------
    {
      "name": "Jest: @euno/mcp (full suite)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/jest",
      "runtimeArgs": ["--forceExit", "--runInBand"],
      "cwd": "${workspaceFolder}/public/packages/mcp",
      "env": {},
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "tests",
        "order": 2
      }
    },
    // -------------------------------------------------------------------------
    // Jest tests — @euno/langchain full suite
    // -------------------------------------------------------------------------
    {
      "name": "Jest: @euno/langchain (full suite)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/jest",
      "runtimeArgs": ["--forceExit", "--runInBand"],
      "cwd": "${workspaceFolder}/public/packages/langchain",
      "env": {},
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "tests",
        "order": 3
      }
    },
    // -------------------------------------------------------------------------
    // Jest tests — @euno/common-core full suite
    // -------------------------------------------------------------------------
    {
      "name": "Jest: @euno/common-core (full suite)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/jest",
      "runtimeArgs": ["--forceExit", "--runInBand"],
      "cwd": "${workspaceFolder}/public/packages/common",
      "env": {},
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "tests",
        "order": 4
      }
    },
    // -------------------------------------------------------------------------
    // Stage 3 readiness script
    // -------------------------------------------------------------------------
    {
      "name": "Stage 3 readiness check",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--require", "ts-node/register"],
      "args": ["${workspaceFolder}/scripts/stage3-readiness.ts"],
      "cwd": "${workspaceFolder}",
      "env": {
        "TS_NODE_PROJECT": "${workspaceFolder}/tsconfig.json"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "scripts",
        "order": 1
      }
    }
  ],
  "inputs": [
    {
      "id": "policyFile",
      "type": "promptString",
      "description": "Path to euno.policy.yaml",
      "default": "${workspaceFolder}/public/packages/mcp/policies/postgres.policy.yaml"
    },
    {
      "id": "upstreamScript",
      "type": "promptString",
      "description": "Path to the upstream MCP server script",
      "default": "${workspaceFolder}/public/packages/mcp/test/fixtures/mock-upstream.ts"
    },
    {
      "id": "requestId",
      "type": "promptString",
      "description": "Audit record request ID (metadata.uid)"
    }
  ]
}
