# CODEOWNERS — package ownership
#
# This file is the canonical source of code ownership for the current
# two-folder workspace layout. GitHub will request reviews from the matching
# team(s) automatically on every PR.
#
# Team handles below are placeholders — replace `@edgeobs/<team>` with
# the actual GitHub team slugs in your organization before merging.

# ---------------------------------------------------------------------------
# Default owners — any path not matched below requires a review from the
# pilot leads.
# ---------------------------------------------------------------------------
*                                       @edgeobs/euno-leads

# ---------------------------------------------------------------------------
# Control Plane (CP) — capability issuance, signing, identity adapters
# ---------------------------------------------------------------------------
/euno-platform/packages/capability-issuer/            @edgeobs/euno-cp
/euno-platform/packages/partner-issuer-sim/           @edgeobs/euno-cp

# ---------------------------------------------------------------------------
# Data Plane (DP) — gateway enforcement, agent runtime, kill switch,
# revocation
# ---------------------------------------------------------------------------
/euno-platform/packages/tool-gateway/                 @edgeobs/euno-dp
/euno-platform/packages/agent-runtime/                @edgeobs/euno-dp

# ---------------------------------------------------------------------------
# Observability & Compliance (OBS) — posture, audit, infra, k8s
# ---------------------------------------------------------------------------
/euno-platform/packages/posture-emitter/              @edgeobs/euno-obs
/infra/                                 @edgeobs/euno-obs
/k8s/                                   @edgeobs/euno-obs

# ---------------------------------------------------------------------------
# Developer Experience (DX) — CLI, framework adapters, web UI
# ---------------------------------------------------------------------------
/public/packages/cli/                                @edgeobs/euno-dx
/public/packages/mcp/                                @edgeobs/euno-dx
/public/packages/langchain/                          @edgeobs/euno-dx
/euno-platform/packages/framework-adapters/           @edgeobs/euno-dx
/web/                                   @edgeobs/euno-dx

# ---------------------------------------------------------------------------
# Shared code — both CP and DP must approve because behaviour changes
# can affect either side of the trust boundary.
# ---------------------------------------------------------------------------
/public/packages/common/                              @edgeobs/euno-cp @edgeobs/euno-dp @edgeobs/euno-dx
/euno-platform/packages/common/                       @edgeobs/euno-cp @edgeobs/euno-dp
/euno-platform/packages/common-infra/                 @edgeobs/euno-cp @edgeobs/euno-dp

# ---------------------------------------------------------------------------
# Integration tests — owned by both DP and DX (DX writes them, DP runs
# them in CI).
# ---------------------------------------------------------------------------
/euno-platform/packages/integration-tests/            @edgeobs/euno-dp @edgeobs/euno-dx

# ---------------------------------------------------------------------------
# Documentation — owned by the pilot leads. Doc-only changes still
# require lead approval; substantive changes to architecture or
# security docs should additionally loop in the relevant team's
# subject-matter reviewers on a per-PR basis.
# ---------------------------------------------------------------------------
/docs/                                  @edgeobs/euno-leads
/docs/capability-model.md               @edgeobs/euno-leads
/docs/enforcement.md                    @edgeobs/euno-leads
/docs/sandboxing.md                     @edgeobs/euno-leads
/docs/SPRINT_*.md                       @edgeobs/euno-leads
/README.md                              @edgeobs/euno-leads

# ---------------------------------------------------------------------------
# Repository-wide configuration — pilot leads only.
# ---------------------------------------------------------------------------
/CODEOWNERS                             @edgeobs/euno-leads
/package.json                           @edgeobs/euno-leads
/tsconfig.json                          @edgeobs/euno-leads
/.eslintrc.json                         @edgeobs/euno-leads
