{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/tests"],
  "testMatch": ["**/*.test.ts"],
  "moduleFileExtensions": ["ts", "js"],
  "collectCoverage": false,
  "coverageDirectory": "coverage",
  "coveragePathIgnorePatterns": ["/node_modules/", "/dist/"],
  "verbose": true,
  "moduleNameMapper": {
    "^@euno/agent-runtime$": "<rootDir>/../agent-runtime/src/index.ts"
  }
}
