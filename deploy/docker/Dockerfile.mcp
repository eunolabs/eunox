# SPDX-License-Identifier: Apache-2.0
#
# Multi-stage Dockerfile for the eunox-mcp proxy (Linux).
# Produces a distroless image for linux/amd64 and linux/arm64.
#
# Usage:
#   docker build -f deploy/docker/Dockerfile.mcp -t eunolabs/eunox-mcp:latest .

# ── Build stage ──────────────────────────────────────────────────────────────
FROM golang:1.25-alpine AS builder

ARG VERSION=0.0.0
ARG TARGETOS=linux
ARG TARGETARCH=amd64

# git: VCS stamp; ca-certificates + tzdata: copied into the distroless final stage.
RUN apk add --no-cache git ca-certificates tzdata

WORKDIR /src

# Cache module downloads independently of source changes.
COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build \
    -trimpath \
    -ldflags="-s -w -X main.version=${VERSION} -buildid=" \
    -o /out/mcp \
    ./cmd/mcp/

# ── Final stage (distroless/nonroot) ────────────────────────────────────────
FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=builder /usr/share/zoneinfo /usr/share/zoneinfo
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=builder /out/mcp /usr/local/bin/mcp

# UID 65534 = nonroot in distroless.
USER 65534:65534

LABEL org.opencontainers.image.source="https://github.com/eunolabs/eunox"
LABEL org.opencontainers.image.licenses="Apache-2.0"
LABEL org.opencontainers.image.vendor="Eunox"
LABEL org.opencontainers.image.description="Eunox MCP capability enforcement proxy"

ENTRYPOINT ["/usr/local/bin/mcp"]
