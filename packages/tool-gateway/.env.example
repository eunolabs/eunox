# Tool Gateway Environment Configuration
# Copy this file to .env and fill in the values

# Service Configuration
NODE_ENV=development
PORT=3002

# Capability Issuer Configuration
# URL to fetch the public key from the Capability Issuer
ISSUER_PUBLIC_KEY_URL=http://localhost:3001/api/v1/public-key

# Backend Service Configuration
# URL of the backend service to proxy requests to
BACKEND_SERVICE_URL=http://localhost:4000

# Admin API Configuration
# Optional: Set an API key to require authentication for admin endpoints
# If not set, admin endpoints will be publicly accessible (not recommended for production)
# ADMIN_API_KEY=your-secure-random-key-here

# Cryptographic Audit Configuration
# Enable cryptographic evidence generation for audit trail.
# When set to `true`, the gateway requires an evidence signer to be
# configured at startup. If no signer can be constructed the process
# exits with an error rather than silently emitting unsigned evidence.
ENABLE_CRYPTOGRAPHIC_AUDIT=false

# Evidence signer (used when ENABLE_CRYPTOGRAPHIC_AUDIT=true).
# Provide ONE of:
#   * EVIDENCE_SIGNING_KEY_PEM  — inline PEM-encoded private key.
#   * EVIDENCE_SIGNING_KEY_FILE — path to a PEM file on disk.
# Optionally:
#   * EVIDENCE_SIGNING_PUBLIC_KEY_PEM / EVIDENCE_SIGNING_PUBLIC_KEY_FILE
#       — public key (otherwise derived from the private key).
#   * EVIDENCE_SIGNING_ALGORITHM — defaults to RS256.
#       Supported: RS256/384/512, PS256/384/512, ES256/384/512, EdDSA.
#   * EVIDENCE_SIGNING_KEY_ID    — defaults to `software-key`.
# For KMS-backed signing, supply an EvidenceSigner programmatically when
# constructing the EnforcementEngine instead of using these env vars.
# EVIDENCE_SIGNING_KEY_FILE=/etc/euno/evidence-signer.pem
# EVIDENCE_SIGNING_ALGORITHM=RS256
# EVIDENCE_SIGNING_KEY_ID=tool-gateway-evidence-key

# Audit Log Tamper-Evidence
# Audit log entries automatically carry an `auditChain` field with seq,
# prevHash, and hash for tamper evidence. Set the seed below to the
# previous run's terminal hash to maintain chain continuity across
# process restarts (one variable per service name, uppercased).
# EUNO_AUDIT_CHAIN_SEED_TOOL_GATEWAY=<sha256-of-last-record>

# Policy Version
# Version identifier for the current policy
POLICY_VERSION=1.0.0

# Logging Configuration
ENABLE_DETAILED_LOGGING=false

# ----------------------------------------------------------------------------
# CORS / Origin Allow-list
# ----------------------------------------------------------------------------
# Comma-separated list of origins allowed to call the gateway from a browser.
# In production this MUST be set to the exact list of front-end domains; when
# unset and NODE_ENV=production the gateway disables CORS entirely (no
# browser origins allowed) to fail safe.
# Examples:
#   ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# ALLOWED_ORIGINS=

# ----------------------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------------------
# Tune these to your expected load.  Defaults (60s window / 1000 requests per
# IP) are intentionally generous for development; production workloads should
# set them based on observed traffic and per-tenant SLOs.  Recommended starting
# points (per gateway instance):
#   - Internal/back-office:   RATE_LIMIT_MAX_REQUESTS=300,  RATE_LIMIT_WINDOW_MS=60000
#   - Public-facing API:      RATE_LIMIT_MAX_REQUESTS=120,  RATE_LIMIT_WINDOW_MS=60000
#   - Bursty agent traffic:   RATE_LIMIT_MAX_REQUESTS=2000, RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=1000

# ----------------------------------------------------------------------------
# Distributed Token Revocation (Redis)
# ----------------------------------------------------------------------------
# When unset the gateway uses an in-process revocation list, which is only
# safe for single-instance deployments.  For multi-instance / production
# deployments set REDIS_URL to a shared Redis endpoint so a revocation issued
# on one gateway is immediately visible on every other gateway.  See
# docs/DISTRIBUTED_REVOCATION.md for the full architecture.
# REDIS_URL=redis://redis-cluster:6379
#
# Optional key prefix (default: "revoked:") used for revoked-token keys.
# REVOCATION_KEY_PREFIX=revoked:
#
# When Redis is unreachable the gateway defaults to fail-CLOSED: lookups are
# treated as "revoked" so a partitioned gateway cannot accept tokens that may
# have been revoked elsewhere.  Set REVOCATION_FAIL_OPEN=true ONLY if
# availability matters more than revocation freshness for your use case.
# REVOCATION_FAIL_OPEN=false

