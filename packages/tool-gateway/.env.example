# Tool Gateway environment configuration.
# AUTO-GENERATED FROM `@euno/common` EunoConfig schema (R-5).
# Re-run `euno config dump-template --service gateway > .env.example` after
# editing the schema. Do not edit this file by hand.

# Deployment environment. Used by logging and CORS to pick safe defaults.
NODE_ENV=development

# TCP port the gateway HTTP server binds to.
PORT=3002

# ── JWKS / key-rotation (R-6) ──────────────────────────────────────────────

# URL of the issuer's JWKS endpoint. Replaces the single SPKI fetch so the
# gateway can verify tokens after a key rotation without a restart.
# Default: http://localhost:3001/.well-known/jwks.json
# ISSUER_JWKS_URL=<value>

# DEPRECATED: use ISSUER_JWKS_URL instead. If set, the gateway will log a
# deprecation warning and derive the JWKS URL from the base of this URL.
# URL the gateway called to fetch the issuer public key (single SPKI).
# ISSUER_PUBLIC_KEY_URL=<value>

# How long (in seconds) the gateway caches the JWKS fetched from the issuer.
# After this window the next token verification triggers a background refresh.
# Default: 300 (5 minutes).
# EUNO_JWKS_CACHE_TTL_SECONDS=300

# When true, tokens that do not include a `kid` claim in their JWS protected
# header are rejected outright (fail-closed). Set to false ONLY during a
# rolling deploy where some tokens may still lack a `kid` (transition window).
# Default: true.
# EUNO_REQUIRE_KID=true

# ── Proxy / backend ─────────────────────────────────────────────────────────

# URL of the backend service the gateway proxies authorised requests to.
# Defaults to http://localhost:4000.
# BACKEND_SERVICE_URL=<value>

# Optional API key required to call /admin endpoints. When unset, the admin
# API is publicly reachable (NOT recommended for production).
# ADMIN_API_KEY=<value>

# Sign every audit-trail entry with the configured evidence signer. When true,
# an evidence signer MUST be configured or the process exits.
ENABLE_CRYPTOGRAPHIC_AUDIT=false

# Inline PEM-encoded private key for evidence signing. Provide this OR
# EVIDENCE_SIGNING_KEY_FILE.
# EVIDENCE_SIGNING_KEY_PEM=<value>

# Path to a PEM file containing the evidence signing private key. Provide this
# OR EVIDENCE_SIGNING_KEY_PEM.
# EVIDENCE_SIGNING_KEY_FILE=<value>

# Optional inline PEM public key. Derived from the private key when unset.
# EVIDENCE_SIGNING_PUBLIC_KEY_PEM=<value>

# Optional path to a PEM file containing the evidence public key.
# EVIDENCE_SIGNING_PUBLIC_KEY_FILE=<value>

# Evidence signing algorithm. Defaults to RS256. Supported: RS256/384/512,
# PS256/384/512, ES256/384/512, EdDSA.
# EVIDENCE_SIGNING_ALGORITHM=<value>

# Evidence signing key id. Defaults to "software-key".
# EVIDENCE_SIGNING_KEY_ID=<value>

# Seed the gateway audit chain with the previous run's terminal hash to
# maintain tamper-evidence continuity across restarts.
# EUNO_AUDIT_CHAIN_SEED_TOOL_GATEWAY=<value>

# Version identifier for the active policy (string, default "1.0.0").
# POLICY_VERSION=<value>

# Enable verbose request / decision logs. Boolean: true | false.
ENABLE_DETAILED_LOGGING=false

# Comma-separated list of browser origins allowed to call the gateway. In
# production the gateway disables CORS entirely when this is unset
# (fail-safe).
# ALLOWED_ORIGINS=<value>

# Rate-limit window in milliseconds. Default 60000 (60 s). See README for
# tuning guidance.
RATE_LIMIT_WINDOW_MS=60000

# Max requests per IP per RATE_LIMIT_WINDOW_MS. Default 1000 (development);
# tighten in production.
RATE_LIMIT_MAX_REQUESTS=1000

# Comma-separated list of partner issuer DIDs whose capability tokens this
# gateway will accept. Empty / unset = local issuer only.
# TRUSTED_PARTNER_DIDS=<value>

# Comma-separated list of identifiers treated as the local issuer (in addition
# to ISSUER_JWKS_URL).
# LOCAL_ISSUER_IDS=<value>

# Optional shared Redis URL. When set, revocation, kill-switch, and maxCalls
# counter state propagate across gateway replicas. Required for multi-instance
# deployments.
# REDIS_URL=<value>

# Optional Redis key prefix for revoked-token entries. Default "revoked:".
# REVOCATION_KEY_PREFIX=<value>

# When Redis is unreachable, treat lookups as "not revoked" instead of
# "revoked". Use ONLY if availability matters more than revocation freshness.
# Boolean: true | false.
REVOCATION_FAIL_OPEN=false

# Optional Redis key prefix for kill-switch entries. Default "killswitch:".
# KILL_SWITCH_KEY_PREFIX=<value>

# Background refresh interval in ms for the kill-switch state. Smaller =
# faster propagation, more Redis traffic. Default 5000.
KILL_SWITCH_REFRESH_INTERVAL_MS=5000

# When true, kill-switch writes that fail against Redis still update the local
# cache. Default false. Boolean: true | false.
KILL_SWITCH_FAIL_OPEN_ON_WRITE=false

# Optional Redis key prefix for maxCalls counter entries. Default "capcall:".
# CALL_COUNTER_KEY_PREFIX=<value>
