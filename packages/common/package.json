{
  "name": "@euno/common",
  "version": "1.0.0",
  "description": "Common types, interfaces, and utilities for Euno agent governance",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./wire": {
      "types": "./dist/wire.d.ts",
      "default": "./dist/wire.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./verify-evidence-job": {
      "types": "./dist/verify-evidence-job.d.ts",
      "default": "./dist/verify-evidence-job.js"
    },
    "./action-resolver": {
      "types": "./dist/action-resolver.d.ts",
      "default": "./dist/action-resolver.js"
    },
    "./openapi/capability-issuer": {
      "types": "./dist/generated/capability-issuer.d.ts",
      "default": "./dist/generated/capability-issuer.js"
    },
    "./openapi/tool-gateway": {
      "types": "./dist/generated/tool-gateway.d.ts",
      "default": "./dist/generated/tool-gateway.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "wire": [
        "dist/wire.d.ts"
      ],
      "runtime": [
        "dist/runtime.d.ts"
      ],
      "types": [
        "dist/types.d.ts"
      ],
      "verify-evidence-job": [
        "dist/verify-evidence-job.d.ts"
      ],
      "action-resolver": [
        "dist/action-resolver.d.ts"
      ],
      "openapi/capability-issuer": [
        "dist/generated/capability-issuer.d.ts"
      ],
      "openapi/tool-gateway": [
        "dist/generated/tool-gateway.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^1.30.1",
    "@opentelemetry/core": "^1.30.1",
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "jose": "^5.2.0",
    "prom-client": "^15.1.3",
    "ts-jest": "^29.4.9",
    "winston": "^3.17.0",
    "winston-transport": "^4.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "express": "^4.18.2",
    "openapi-typescript": "^7.13.0",
    "supertest": "^6.3.4",
    "typescript": "^5.3.3"
  },
  "license": "BUSL-1.1"
}
