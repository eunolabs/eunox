# Capability Issuer Environment Configuration
# Copy this file to .env and fill in the values

# Service Configuration
NODE_ENV=development
PORT=3001

# Azure Key Vault Configuration (required for token signing)
AZURE_KEYVAULT_URL=https://your-vault.vault.azure.net/
AZURE_KEYVAULT_KEY_NAME=capability-signing-key
# AZURE_KEYVAULT_KEY_VERSION=  # Optional: specific version, defaults to latest

# Azure Credential Type
# Options: default, managed-identity, client-secret
AZURE_CREDENTIAL_TYPE=default

# Azure Service Principal (required if using client-secret credential type)
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=

# Azure AD Configuration (required for user authentication)
AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_CLIENT_ID=your-app-client-id
# AZURE_AD_CLIENT_SECRET=  # Optional: for Graph API access
# AZURE_AD_AUTHORITY=https://login.microsoftonline.com/your-tenant-id

# Issuer DID Configuration
# Use did:web for DNS-anchored DIDs or did:ion for blockchain-anchored DIDs
ISSUER_DID=did:web:yourdomain.com

# Token Configuration
# Token TTL in seconds (default: 900 = 15 minutes)
DEFAULT_TOKEN_TTL=900

# Logging Configuration
ENABLE_DETAILED_LOGGING=false
