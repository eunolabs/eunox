# Capability Issuer Environment Configuration
# Copy this file to .env and fill in the values

# Service Configuration
NODE_ENV=development
PORT=3001

# Signing Provider Selection
# Options: azure-keyvault, aws-kms, gcp-cloudkms
SIGNING_PROVIDER=azure-keyvault

# Azure Key Vault Configuration (required if SIGNING_PROVIDER=azure-keyvault)
AZURE_KEYVAULT_URL=https://your-vault.vault.azure.net/
AZURE_KEYVAULT_KEY_NAME=capability-signing-key
# AZURE_KEYVAULT_KEY_VERSION=  # Optional: specific version, defaults to latest

# Azure Credential Type
# Options: default, managed-identity, client-secret
AZURE_CREDENTIAL_TYPE=default

# Azure Service Principal (required if using client-secret credential type)
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=

# AWS KMS Configuration (required if SIGNING_PROVIDER=aws-kms)
# AWS_KMS_REGION=us-east-1
# AWS_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012
# AWS_ACCESS_KEY_ID=  # Optional: uses default credentials if not provided
# AWS_SECRET_ACCESS_KEY=  # Optional: uses default credentials if not provided
# AWS_SESSION_TOKEN=  # Optional: for temporary credentials

# GCP Cloud KMS Configuration (required if SIGNING_PROVIDER=gcp-cloudkms)
# GCP_PROJECT_ID=my-project-id
# GCP_LOCATION_ID=us-central1
# GCP_KEYRING_ID=my-key-ring
# GCP_CRYPTOKEY_ID=my-crypto-key
# GCP_CRYPTOKEY_VERSION=  # Optional: uses primary version if not specified
# GCP_KEY_FILE_PATH=  # Optional: path to service account key file, uses default credentials if not provided

# Identity Provider Selection
# Options: azure-ad, aws-cognito, gcp-identity, did
IDENTITY_PROVIDER=azure-ad

# Azure AD Configuration (required for user authentication if IDENTITY_PROVIDER=azure-ad)
AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_CLIENT_ID=your-app-client-id
# AZURE_AD_CLIENT_SECRET=  # Optional: for Graph API access
# AZURE_AD_AUTHORITY=https://login.microsoftonline.com/your-tenant-id

# AWS Cognito / IAM Identity Center Configuration
# Required if IDENTITY_PROVIDER=aws-cognito. Use either a Cognito user pool
# (AWS_COGNITO_USER_POOL_ID + AWS_COGNITO_CLIENT_ID) or a generic OIDC issuer
# such as IAM Identity Center (AWS_COGNITO_ISSUER + AWS_COGNITO_CLIENT_ID).
# AWS_COGNITO_REGION=us-east-1
# AWS_COGNITO_USER_POOL_ID=us-east-1_ExamplePool
# AWS_COGNITO_CLIENT_ID=example-client-id
# AWS_COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_ExamplePool
# AWS_COGNITO_JWKS_URI=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_ExamplePool/.well-known/jwks.json
# AWS_COGNITO_TOKEN_USE=id  # Optional: id or access

# GCP Identity Configuration (required if IDENTITY_PROVIDER=gcp-identity)
# GCP_IDENTITY_AUDIENCE=your-oauth-client-id.apps.googleusercontent.com
# GCP_IDENTITY_ISSUER=https://accounts.google.com
# GCP_IDENTITY_JWKS_URI=https://www.googleapis.com/oauth2/v3/certs
# GCP_IDENTITY_PROJECT_ID=my-project-id
# GCP_IDENTITY_ROLES_CLAIM=roles

# DID Identity Configuration (required if IDENTITY_PROVIDER=did)
# DID tokens are validated against DID Documents for did:web, did:ion, and
# did:key. did:ion uses the public Microsoft resolver by default; override for
# private/self-hosted ION deployments.
# ION_RESOLVER_URL=https://ion.msidentity.com/api/v1.0/identifiers

# Issuer DID Configuration
# Use did:web for DNS-anchored DIDs or did:ion for blockchain-anchored DIDs
ISSUER_DID=did:web:yourdomain.com

# Token Configuration
# Token TTL in seconds (default: 900 = 15 minutes)
DEFAULT_TOKEN_TTL=900

# Role → Capability Policy
# Optional path to a JSON file describing the externalised role policy.
# When unset, the in-code Sprint-1 default mapping is used.
# The file must have shape:
#   {
#     "default": { "<RoleName>": [ { "resource": "...", "actions": ["read", ...] }, ... ], ... },
#     "tenants": { "<tenantId>": { "<RoleName>": [ ... ] | [], ... }, ... }
#   }
# Per-tenant entries are merged on top of `default` per role; supplying an
# empty array (or `null`) for a role removes it for that tenant.
# ROLE_POLICY_FILE=/etc/euno/role-policy.json

# Logging Configuration
ENABLE_DETAILED_LOGGING=false

# ---------------------------------------------------------------------------
# Cloud storage grants (Sprint 3-4 gap #7)
# ---------------------------------------------------------------------------
# When enabled, the issuer mints short-lived cloud storage credentials
# (Azure Blob SAS, S3 presigned URLs / STS sessions, GCS signed URLs /
# downscoped tokens) alongside every capability whose resource matches
# the canonical `storage://{cloud}/{bucket}/{key-or-prefix}` form. See
# docs/sprint-3-4-gaps/07-storage-grants.md.
#
# Disabled by default. Enable per cloud by also installing the
# corresponding optional SDK dependency (see package.json
# optionalDependencies).
# STORAGE_GRANTS_ENABLED=false
# STORAGE_GRANT_MAX_TTL_SECONDS=900           # default 900 (15 min); hard ceiling 3600
# AWS_STORAGE_GRANT_ROLE_ARN=arn:aws:iam::123456789012:role/euno-storage-grant
# AWS_REGION=us-east-1                          # already used by other AWS components

# ---------------------------------------------------------------------------
# Database credential issuance (Sprint 3-4 gap #8)
# ---------------------------------------------------------------------------
# When enabled, the issuer mints short-lived IAM-bound database
# credentials (Azure SQL AAD tokens, RDS IAM auth tokens, Cloud SQL
# OAuth tokens) alongside every capability whose resource matches the
# canonical `db://{cloud}/{instance}/{database}/{schema-or-table}.{action}`
# form. See docs/sprint-3-4-gaps/08-db-token-issuance.md.
#
# DB_INSTANCES_FILE is REQUIRED when enabled — the issuer refuses to
# start with no operator-declared allow-list of permitted DB instances.
# DB_TOKENS_ENABLED=false
# DB_TOKEN_MAX_TTL_SECONDS=900                  # default 900 (15 min); hard ceiling 900
# DB_INSTANCES_FILE=/etc/euno/db-instances.json
