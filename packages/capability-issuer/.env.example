# Capability Issuer Environment Configuration
# Copy this file to .env and fill in the values

# Service Configuration
NODE_ENV=development
PORT=3001

# Signing Provider Selection
# Options: azure-keyvault, aws-kms, gcp-cloudkms
SIGNING_PROVIDER=azure-keyvault

# Azure Key Vault Configuration (required if SIGNING_PROVIDER=azure-keyvault)
AZURE_KEYVAULT_URL=https://your-vault.vault.azure.net/
AZURE_KEYVAULT_KEY_NAME=capability-signing-key
# AZURE_KEYVAULT_KEY_VERSION=  # Optional: specific version, defaults to latest

# Azure Credential Type
# Options: default, managed-identity, client-secret
AZURE_CREDENTIAL_TYPE=default

# Azure Service Principal (required if using client-secret credential type)
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=

# AWS KMS Configuration (required if SIGNING_PROVIDER=aws-kms)
# AWS_KMS_REGION=us-east-1
# AWS_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012
# AWS_ACCESS_KEY_ID=  # Optional: uses default credentials if not provided
# AWS_SECRET_ACCESS_KEY=  # Optional: uses default credentials if not provided
# AWS_SESSION_TOKEN=  # Optional: for temporary credentials

# GCP Cloud KMS Configuration (required if SIGNING_PROVIDER=gcp-cloudkms)
# GCP_PROJECT_ID=my-project-id
# GCP_LOCATION_ID=us-central1
# GCP_KEYRING_ID=my-key-ring
# GCP_CRYPTOKEY_ID=my-crypto-key
# GCP_CRYPTOKEY_VERSION=  # Optional: uses primary version if not specified
# GCP_KEY_FILE_PATH=  # Optional: path to service account key file, uses default credentials if not provided

# Identity Provider Selection
# Options: azure-ad, did
IDENTITY_PROVIDER=azure-ad

# Azure AD Configuration (required for user authentication if IDENTITY_PROVIDER=azure-ad)
AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_CLIENT_ID=your-app-client-id
# AZURE_AD_CLIENT_SECRET=  # Optional: for Graph API access
# AZURE_AD_AUTHORITY=https://login.microsoftonline.com/your-tenant-id

# Issuer DID Configuration
# Use did:web for DNS-anchored DIDs or did:ion for blockchain-anchored DIDs
ISSUER_DID=did:web:yourdomain.com

# Token Configuration
# Token TTL in seconds (default: 900 = 15 minutes)
DEFAULT_TOKEN_TTL=900

# Role → Capability Policy
# Optional path to a JSON file describing the externalised role policy.
# When unset, the in-code Sprint-1 default mapping is used.
# The file must have shape:
#   {
#     "default": { "<RoleName>": [ { "resource": "...", "actions": ["read", ...] }, ... ], ... },
#     "tenants": { "<tenantId>": { "<RoleName>": [ ... ] | [], ... }, ... }
#   }
# Per-tenant entries are merged on top of `default` per role; supplying an
# empty array (or `null`) for a role removes it for that tenant.
# ROLE_POLICY_FILE=/etc/euno/role-policy.json

# Logging Configuration
ENABLE_DETAILED_LOGGING=false
