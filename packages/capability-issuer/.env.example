# Capability Issuer environment configuration.
# AUTO-GENERATED FROM `@euno/common` EunoConfig schema (R-5).
# Re-run `euno config dump-template --service issuer > .env.example` after
# editing the schema. Do not edit this file by hand.

# Deployment environment. Used by logging and CORS to pick safe defaults.
NODE_ENV=development

# TCP port the issuer HTTP server binds to.
PORT=3001

# Token signing provider. One of: azure-keyvault, aws-kms, gcp-cloudkms.
SIGNING_PROVIDER=azure-keyvault

# ── JWKS / key-rotation (R-6) ──────────────────────────────────────────────
# The issuer publishes GET /.well-known/jwks.json automatically — no extra
# configuration is required for a single-key setup. The key set is derived
# from the active signer's public key + key ID at request time.
#
# Future: set ISSUER_SECONDARY_KEY_ID=<kid> to include a second key in the
# JWKS during a rotation overlap window (add key 2 → wait one gateway TTL →
# flip SIGNING_PROVIDER / key → wait one TTL → remove old key).

# Identity provider used to authenticate /issue callers. One of: azure-ad,
# aws-cognito, gcp-identity, did.
IDENTITY_PROVIDER=azure-ad

# Azure Key Vault URL (required when SIGNING_PROVIDER=azure-keyvault).
# Example: https://your-vault.vault.azure.net/
AZURE_KEYVAULT_URL=<value>

# Azure Key Vault key name. Defaults to "capability-signing-key".
# AZURE_KEYVAULT_KEY_NAME=<value>

# Optional specific Key Vault key version. Defaults to latest.
# AZURE_KEYVAULT_KEY_VERSION=<value>

# Azure credential type used to authenticate to Key Vault and Graph. One of:
# default, managed-identity, client-secret.
AZURE_CREDENTIAL_TYPE=default

# Azure service principal client ID (required when
# AZURE_CREDENTIAL_TYPE=client-secret).
# AZURE_CLIENT_ID=<value>

# Azure service principal client secret (required when
# AZURE_CREDENTIAL_TYPE=client-secret).
# AZURE_CLIENT_SECRET=<value>

# Azure tenant ID (required when AZURE_CREDENTIAL_TYPE=client-secret).
# AZURE_TENANT_ID=<value>

# AWS region of the KMS key. Defaults to us-east-1 when
# SIGNING_PROVIDER=aws-kms.
# AWS_KMS_REGION=<value>

# AWS KMS key ARN or ID (required when SIGNING_PROVIDER=aws-kms).
# AWS_KMS_KEY_ID=<value>

# AWS access key. Optional; falls back to the default credential provider
# chain.
# AWS_ACCESS_KEY_ID=<value>

# AWS secret access key. Optional; falls back to the default credential
# provider chain.
# AWS_SECRET_ACCESS_KEY=<value>

# AWS session token, for temporary credentials. Optional.
# AWS_SESSION_TOKEN=<value>

# GCP project ID (required when SIGNING_PROVIDER=gcp-cloudkms).
# GCP_PROJECT_ID=<value>

# GCP KMS location. Defaults to us-central1.
# GCP_LOCATION_ID=<value>

# GCP KMS key ring ID (required when SIGNING_PROVIDER=gcp-cloudkms).
# GCP_KEYRING_ID=<value>

# GCP KMS crypto key ID (required when SIGNING_PROVIDER=gcp-cloudkms).
# GCP_CRYPTOKEY_ID=<value>

# Optional GCP KMS crypto key version. Defaults to the primary version.
# GCP_CRYPTOKEY_VERSION=<value>

# Optional path to a GCP service account key file. Falls back to ADC when
# unset.
# GCP_KEY_FILE_PATH=<value>

# Azure AD tenant ID (required when IDENTITY_PROVIDER=azure-ad).
# AZURE_AD_TENANT_ID=<value>

# Azure AD application client ID (required when IDENTITY_PROVIDER=azure-ad).
# AZURE_AD_CLIENT_ID=<value>

# Azure AD client secret. Optional; required only when the issuer needs
# Microsoft Graph access.
# AZURE_AD_CLIENT_SECRET=<value>

# Azure AD authority URL. Example:
# https://login.microsoftonline.com/<tenant-id>
# AZURE_AD_AUTHORITY=<value>

# Cognito / IAM Identity Center region (e.g. us-east-1).
# AWS_COGNITO_REGION=<value>

# Cognito user pool ID. Provide this OR AWS_COGNITO_ISSUER plus
# AWS_COGNITO_CLIENT_ID.
# AWS_COGNITO_USER_POOL_ID=<value>

# Cognito / OIDC client ID (required when IDENTITY_PROVIDER=aws-cognito).
# AWS_COGNITO_CLIENT_ID=<value>

# OIDC issuer URL for IAM Identity Center or generic OIDC. Provide this OR
# AWS_COGNITO_USER_POOL_ID.
# AWS_COGNITO_ISSUER=<value>

# Optional explicit JWKS URI. Derived from issuer when unset.
# AWS_COGNITO_JWKS_URI=<value>

# Which Cognito token kind to validate. One of: id, access. Optional.
# AWS_COGNITO_TOKEN_USE=id | access

# OAuth client ID / audience for GCP identity tokens (required when
# IDENTITY_PROVIDER=gcp-identity).
# GCP_IDENTITY_AUDIENCE=<value>

# GCP identity token issuer. Defaults to https://accounts.google.com.
# GCP_IDENTITY_ISSUER=<value>

# GCP identity token JWKS URI. Defaults to
# https://www.googleapis.com/oauth2/v3/certs.
# GCP_IDENTITY_JWKS_URI=<value>

# Optional GCP project ID for identity validation.
# GCP_IDENTITY_PROJECT_ID=<value>

# Optional claim name carrying user roles. Defaults to "roles".
# GCP_IDENTITY_ROLES_CLAIM=<value>

# did:ion resolver URL. Defaults to the public Microsoft resolver. Override
# for self-hosted ION.
# ION_RESOLVER_URL=<value>

# Issuer DID. Defaults to did:web:example.com if unset (development only — set
# explicitly in production).
# ISSUER_DID=<value>

# Default capability-token TTL in seconds (default 900 = 15 minutes).
DEFAULT_TOKEN_TTL=900

# Require explicit user consent before issuing high-privilege tokens. Boolean:
# true | false.
REQUIRE_USER_CONSENT=false

# Optional path to a JSON file describing the externalised role policy. Falls
# back to the in-code default mapping.
# ROLE_POLICY_FILE=<value>

# Optional path to a JSON file describing the ActionResolver (R-7) used to (a)
# derive capability actions from incoming HTTP / tool invocations and (b) map
# actions to Conditional-Access tiers. Recognised top-level keys:
# `httpMethodActions`, `defaultHttpAction`, `toolActions`,
# `defaultToolAction`, `actionTiers`, `defaultTier`. Operator entries are
# merged on top of the built-in defaults so the file only needs to declare
# deployment-specific verbs (e.g. `db:select`, `acknowledge_alert`). The same
# file should be configured on the capability-issuer AND the tool-gateway so
# mint-time CA tiering and enforcement-time action derivation share a single
# vocabulary.
# ACTION_RESOLVER_FILE=<value>

# Enable verbose request / decision logs. Boolean: true | false.
ENABLE_DETAILED_LOGGING=false

# Mint cloud-storage credentials alongside capability tokens. See
# docs/sprint-3-4-gaps/07-storage-grants.md.
STORAGE_GRANTS_ENABLED=false

# Cap on storage grant TTL in seconds. Default 900; hard ceiling 3600.
STORAGE_GRANT_MAX_TTL_SECONDS=900

# IAM role ARN the issuer assumes to mint AWS storage grants.
# AWS_STORAGE_GRANT_ROLE_ARN=<value>

# Default AWS region used by storage / DB token issuance.
# AWS_REGION=<value>

# Mint short-lived database credentials alongside capability tokens. See
# docs/sprint-3-4-gaps/08-db-token-issuance.md.
DB_TOKENS_ENABLED=false

# Cap on DB token TTL in seconds. Default 900; hard ceiling 900.
DB_TOKEN_MAX_TTL_SECONDS=900

# REQUIRED when DB_TOKENS_ENABLED=true. Path to the operator-declared
# allow-list of permitted DB instances.
# DB_INSTANCES_FILE=<value>

# Comma-separated list of browser origins allowed to call the issuer. In
# production the issuer disables CORS entirely when this is unset.
# ALLOWED_ORIGINS=<value>
