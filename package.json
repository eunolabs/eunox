{
  "name": "@euno/monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Capability-Native Agent Governance System with Azure Integration",
  "workspaces": [
    "public/packages/*",
    "euno-platform/packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @euno/common-core && npm run build -w @euno/common-infra && npm run build -w @euno/common && npm run build -w @euno/posture-emitter && npm run build -w @euno/mcp && npm run build -w @euno/langchain && npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint:license-boundary && npm run lint --workspaces",
    "lint:license-boundary": "node scripts/check-license-boundary.mjs",
    "test:scripts": "node --test scripts/__tests__/check-license-boundary.test.mjs",
    "clean": "npm run clean --workspaces && rm -rf node_modules",
    "verify-evidence": "node scripts/verify-evidence.js",
    "lint:action-resolver": "node scripts/check-action-resolver-parity.mjs",
    "gen:helm-schema": "node scripts/generate-helm-schema.mjs",
    "gen:helm-schema:check": "node scripts/generate-helm-schema.mjs --check",
    "gen:openapi": "node scripts/generate-openapi-types.mjs",
    "gen:openapi:check": "node scripts/generate-openapi-types.mjs --check",
    "perf": "npm run perf -w @euno/integration-tests",
    "perf:quick": "npm run perf -w @euno/integration-tests -- --quick",
    "perf:slo:emit": "npm run perf:slo:emit -w @euno/integration-tests"
  },
  "keywords": [
    "agent-governance",
    "capability-based-security",
    "azure-integration",
    "decentralized-identity"
  ],
  "author": "EdgeObs",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^8.57.1",
    "typescript": "^5.9.3"
  }
}
