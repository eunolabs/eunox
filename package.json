{
  "name": "@euno/monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Capability-Native Agent Governance System with Azure Integration",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @euno/common && npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "clean": "npm run clean --workspaces && rm -rf node_modules",
    "verify-evidence": "node scripts/verify-evidence.js"
  },
  "keywords": [
    "agent-governance",
    "capability-based-security",
    "azure-integration",
    "decentralized-identity"
  ],
  "author": "EdgeObs",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^8.57.1"
  }
}
