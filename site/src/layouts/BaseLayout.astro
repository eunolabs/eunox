---
export type ActivePage = '' | 'quickstart' | 'features' | 'how-it-works' | 'policies' | 'docs' | 'blog';

interface Props {
  title: string;
  description?: string;
  activePage?: ActivePage;
}

const { title, description = 'Go-based MCP policy proxy. One YAML file enforces what every AI agent is allowed to do — before the tool call reaches your backend. Drop-in. BSL-1.1 · Apache-2.0 OSS tier.', activePage = '' } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path) => `${baseUrl}${path.replace(/^\//, '')}`;

const githubSvg = `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>`;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <link rel="icon" href={withBase('/eunolabs.png')}>
    <link rel="stylesheet" href={withBase('/styles.css')}>
</head>
<body>

    <header class="site-header">
        <div class="header-left">
            <a class="logo" href={withBase('/')}>
                <img src={withBase('/eunolabs.png')} alt="eunox">
                <span class="wordmark">eunox</span>
            </a>
            <span class="stage-badge">GA</span>
        </div>
        <nav class="header-nav" aria-label="Primary">
            <a href={withBase('/quickstart')} class:list={["nav-link", { active: activePage === 'quickstart' }]}>Quick start</a>
            <a href={withBase('/features')} class:list={["nav-link", { active: activePage === 'features' }]}>Features</a>
            <a href={withBase('/how-it-works')} class:list={["nav-link", { active: activePage === 'how-it-works' }]}>How it works</a>
            <a href={withBase('/policies')} class:list={["nav-link", { active: activePage === 'policies' }]}>Policies</a>
            <a href={withBase('/docs')} class:list={["nav-link", { active: activePage === 'docs' }]}>Docs</a>
            <a href={withBase('/blog')} class:list={["nav-link", { active: activePage === 'blog' }]}>Blog</a>
            <a href="https://github.com/edgeobs/eunox" target="_blank" rel="noopener noreferrer" class="btn-github">
                <Fragment set:html={githubSvg} />
                GitHub
            </a>
        </nav>
    </header>

    <slot />

    <footer class="site-footer">
        <div class="footer-grid">
            <div class="footer-col footer-brand">
                <a class="logo" href={withBase('/')}>
                    <img src={withBase('/eunolabs.png')} alt="eunox" style="height:30px">
                    <span class="wordmark">eunox</span>
                </a>
                <p>Capability-native zero-trust governance for AI agents. BSL-1.1 · Apache-2.0 OSS tier.</p>
                <span class="footer-license">BSL-1.1 / Apache-2.0</span>
            </div>
            <div class="footer-col">
                <h5>Product</h5>
                <ul>
                    <li><a href={withBase('/quickstart')}>Quick start</a></li>
                    <li><a href={withBase('/features')}>Features</a></li>
                    <li><a href={withBase('/how-it-works')}>How it works</a></li>
                    <li><a href={withBase('/policies')}>Reference policies</a></li>
                    <li><a href="https://github.com/edgeobs/eunox/blob/main/docs/pricing.md" target="_blank" rel="noopener noreferrer">Pricing</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h5>Resources</h5>
                <ul>
                    <li><a href={withBase('/docs')}>Documentation</a></li>
                    <li><a href="https://github.com/edgeobs/eunox" target="_blank" rel="noopener noreferrer">eunox README</a></li>
                    <li><a href="https://github.com/edgeobs/eunox/blob/main/docs/agent-sdk.md" target="_blank" rel="noopener noreferrer">Go SDK docs</a></li>
                    <li><a href="https://github.com/edgeobs/eunox" target="_blank" rel="noopener noreferrer">Roadmap</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h5>Project</h5>
                <ul>
                    <li><a href="https://github.com/edgeobs/eunox" target="_blank" rel="noopener noreferrer">GitHub</a></li>
                    <li><a href="https://github.com/edgeobs/eunox/issues" target="_blank" rel="noopener noreferrer">Issues</a></li>
                    <li><a href="https://github.com/edgeobs/eunox/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">License</a></li>
                    <li><a href="https://spec.modelcontextprotocol.io/" target="_blank" rel="noopener noreferrer">MCP spec</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <span>&copy; 2026 eunox · An <a href="https://github.com/edgeobs" target="_blank" rel="noopener noreferrer">eunolabs</a> project</span>
            <span>Built for the Model Context Protocol</span>
        </div>
    </footer>

    <script src={withBase('/main.js')}></script>
</body>
</html>
