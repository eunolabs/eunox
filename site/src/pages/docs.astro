---
import BaseLayout from '../layouts/BaseLayout.astro';

const baseUrl = import.meta.env.BASE_URL;
const withBase = (path) => `${baseUrl}${path.replace(/^\//, '')}`;
---
<BaseLayout title="Documentation · eunox" description="Index of eunox documentation: the CLI, Go packages, architecture, deployment, pricing, and operations guidance." activePage="docs">

    <section class="hero hero-compact">
        <div class="hero-eyebrow"><span class="dot"></span>Docs</div>
        <h1>Documentation</h1>
        <p class="hero-sub">CLI docs, Go package entry points, architecture, deployment, and pricing. The authoritative source is the GitHub repo — this page links straight to the relevant files.</p>
    </section>

    <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href={withBase('/')}>Home</a> &nbsp;›&nbsp; Documentation
    </nav>

    <main class="content-section">

        <h2>Get started</h2>
        <ul>
            <li><a href={withBase('/quickstart')}>Quick start</a> — run the proxy in 60 seconds (this site).</li>
            <li><a href={withBase('/features')}>Features</a> — the full condition matrix with worked demos (this site).</li>
            <li><a href={withBase('/how-it-works')}>How it works</a> — architecture, request flow, audit log internals (this site).</li>
            <li><a href={withBase('/policies')}>Reference policies</a> — drop-in YAML for popular MCP servers (this site).</li>
        </ul>

        <h2>CLI &amp; Go packages</h2>
        <ul>
            <li><a href="https://github.com/edgeobs/eunox" target="_blank" rel="noopener noreferrer"><code>eunox-mcp</code></a> — the OSS CLI binary and repo README.</li>
            <li><a href="https://github.com/edgeobs/eunox/blob/main/docs/agent-sdk.md" target="_blank" rel="noopener noreferrer">Go SDK docs</a> — runtime integration guidance for local and hosted enforcement.</li>
            <li><a href="https://github.com/edgeobs/eunox/tree/main/pkg" target="_blank" rel="noopener noreferrer"><code>pkg/</code></a> — public Go packages for capabilities, enforcement, audit, identity, and support libraries.</li>
            <li><a href="https://github.com/edgeobs/eunox/tree/main/cmd" target="_blank" rel="noopener noreferrer"><code>cmd/</code></a> — service entry points for <code>eunox-gateway</code>, <code>eunox-issuer</code>, <code>eunox-minter</code>, <code>eunox-db-token-svc</code>, <code>eunox-storage-grant-svc</code>, and <code>eunox-posture-emitter</code>.</li>
        </ul>

        <h2>Concepts &amp; architecture</h2>
        <table>
            <thead><tr><th>Doc</th><th>What it is</th></tr></thead>
            <tbody>
                <tr>
                    <td><a href="https://github.com/edgeobs/eunox/blob/main/README.md" target="_blank" rel="noopener noreferrer">README.md</a></td>
                    <td>Project overview, service map, repository structure, and Go prerequisites.</td>
                </tr>
                <tr>
                    <td><a href="https://github.com/edgeobs/eunox/blob/main/docs/README.md" target="_blank" rel="noopener noreferrer">docs/README.md</a></td>
                    <td>Documentation index for architecture, operations, and security references.</td>
                </tr>
                <tr>
                    <td><a href="https://github.com/edgeobs/eunox/blob/main/docs/pricing.md" target="_blank" rel="noopener noreferrer">pricing.md</a></td>
                    <td>Pricing tiers and feature boundaries: OSS, Self-Host, Cloud Free, Cloud Team, Cloud Enterprise.</td>
                </tr>
                <tr>
                    <td><a href="https://github.com/edgeobs/eunox/blob/main/docs/architecture.md" target="_blank" rel="noopener noreferrer">architecture.md</a></td>
                    <td>C4 views, service boundaries, deployment views, and sequence diagrams.</td>
                </tr>
                <tr>
                    <td><a href="https://github.com/edgeobs/eunox/blob/main/docs/capability-model.md" target="_blank" rel="noopener noreferrer">capability-model.md</a></td>
                    <td>Security model and capability design.</td>
                </tr>
                <tr>
                    <td><a href="https://github.com/edgeobs/eunox/blob/main/docs/enforcement.md" target="_blank" rel="noopener noreferrer">enforcement.md</a></td>
                    <td>Policy decision point design and enforcement guarantees.</td>
                </tr>
                <tr>
                    <td><a href="https://github.com/edgeobs/eunox/blob/main/docs/capability-manifest-guide.md" target="_blank" rel="noopener noreferrer">capability-manifest-guide.md</a></td>
                    <td>Policy authoring guide for the shared manifest format.</td>
                </tr>
                <tr>
                    <td><a href="https://github.com/edgeobs/eunox/blob/main/docs/repo-guide.md" target="_blank" rel="noopener noreferrer">repo-guide.md</a></td>
                    <td>Repository structure, development setup, and lint/test/build commands.</td>
                </tr>
            </tbody>
        </table>

        <h2>Enterprise &amp; operations</h2>
        <table>
            <thead><tr><th>Doc</th><th>What it is</th></tr></thead>
            <tbody>
                <tr>
                    <td><a href="https://github.com/edgeobs/eunox/blob/main/docs/self-host.md" target="_blank" rel="noopener noreferrer">self-host.md</a></td>
                    <td>Hosted-vs-self-host matrix and the full self-hosted deployment guide.</td>
                </tr>
                <tr>
                    <td><a href="https://github.com/edgeobs/eunox/blob/main/docs/deployment.md" target="_blank" rel="noopener noreferrer">deployment.md</a></td>
                    <td>On-prem bundles, air-gap workflow, and restricted-network deployment checklist.</td>
                </tr>
                <tr>
                    <td><a href="https://github.com/edgeobs/eunox/blob/main/docs/adapters.md" target="_blank" rel="noopener noreferrer">adapters.md</a></td>
                    <td>Pluggable identity and signing adapter reference.</td>
                </tr>
                <tr>
                    <td><a href="https://github.com/edgeobs/eunox/blob/main/docs/agent-sdk.md" target="_blank" rel="noopener noreferrer">agent-sdk.md</a></td>
                    <td>Runtime SDK guidance for agent-side integration.</td>
                </tr>
                <tr>
                    <td><a href="https://github.com/edgeobs/eunox/blob/main/docs/issuer-idp-setup.md" target="_blank" rel="noopener noreferrer">issuer-idp-setup.md</a></td>
                    <td>Identity-provider, SCIM, and issuer deployment recipes.</td>
                </tr>
                <tr>
                    <td><a href="https://github.com/edgeobs/eunox/blob/main/docs/upgrade-to-hosted.md" target="_blank" rel="noopener noreferrer">upgrade-to-hosted.md</a></td>
                    <td>Migrate from local <code>eunox-mcp</code> enforcement to the hosted gateway.</td>
                </tr>
            </tbody>
        </table>

        <h2>Project</h2>
        <ul>
            <li><a href="https://github.com/edgeobs/eunox" target="_blank" rel="noopener noreferrer">Source on GitHub</a> — issues and PRs welcome.</li>
            <li><a href="https://github.com/edgeobs/eunox/issues" target="_blank" rel="noopener noreferrer">Issue tracker</a></li>
            <li><a href="https://github.com/edgeobs/eunox/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">License</a> — BSL-1.1 for server-side services; Apache-2.0 for the OSS <code>eunox-mcp</code> tier.</li>
            <li><a href="https://github.com/edgeobs/eunox/blob/main/CODEOWNERS" target="_blank" rel="noopener noreferrer">CODEOWNERS</a></li>
        </ul>

        <h2>External</h2>
        <ul>
            <li><a href="https://spec.modelcontextprotocol.io/" target="_blank" rel="noopener noreferrer">Model Context Protocol specification</a></li>
            <li><a href="https://schema.ocsf.io/" target="_blank" rel="noopener noreferrer">OCSF — Open Cybersecurity Schema Framework</a></li>
        </ul>
    </main>

</BaseLayout>
